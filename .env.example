# Spotify Web Playback integration
# Required to enable the music player feature.
#
# Setup:
#   1. Go to https://developer.spotify.com/dashboard and create an application.
#   2. In your app settings, add your site URL to "Redirect URIs".
#      For local development add: http://localhost:5173/
#      For production add your deployed URL, e.g.: https://yoursite.com/
#   3. Copy your Client ID below. Do NOT use your Client Secret here —
#      it is not needed (PKCE flow) and must never be exposed client-side.
#
# Notes:
#   - Users must have a Spotify Premium subscription for in-browser playback.
#   - The Client ID is a public identifier; it is safe to commit to version
#     control if needed, but keeping it in .env is good practice.

VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Optional: override the OAuth redirect URI (defaults to window.location.origin + '/')
# VITE_SPOTIFY_REDIRECT_URI=http://localhost:5173/
